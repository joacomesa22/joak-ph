---
import type { ImageMetadata } from 'astro';

interface Props {
	images: ImageMetadata[];
}

const { images } = Astro.props;
---

<div
	id="lightbox"
	class="fixed inset-0 z-50 pointer-events-none opacity-0 transition-opacity duration-300 ease-out"
	style="background: rgba(0,0,0,0);"
	role="dialog"
	aria-modal="true"
>
	<button
		id="lightbox-close"
		class="absolute top-4 right-4 z-10 text-white/70 hover:text-white cursor-pointer opacity-0 transition-all duration-300 delay-150"
		aria-label="Close"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<line x1="18" y1="6" x2="6" y2="18"></line>
			<line x1="6" y1="6" x2="18" y2="18"></line>
		</svg>
	</button>

	<div id="lightbox-swiper" class="swiper w-full h-full">
		<div class="swiper-wrapper items-center">
			{images.map((img) => (
				<div class="swiper-slide flex! items-center justify-center p-12">
					<img
						src={img.src}
						alt=""
						class="max-h-[80vh] max-w-[80vw] object-contain"
						loading="lazy"
					/>
				</div>
			))}
		</div>
		<div class="swiper-button-prev text-white/50! hover:text-white! transition-colors"></div>
		<div class="swiper-button-next text-white/50! hover:text-white! transition-colors"></div>
	</div>
</div>

<script>
	import Swiper from 'swiper';
	import { Navigation, Keyboard } from 'swiper/modules';
	import 'swiper/css';
	import 'swiper/css/navigation';

	const lightbox = document.getElementById('lightbox')!;
	const closeBtn = document.getElementById('lightbox-close')!;
	const swiperWrapper = document.querySelector('#lightbox-swiper .swiper-wrapper')!;
	let isOpen = false;

	// Get visual order of images from the masonry grid
	// CSS columns renders top-to-bottom per column, so we sort by visual position (top then left)
	const triggers = Array.from(document.querySelectorAll('[data-lightbox-trigger]')) as HTMLElement[];
	const visualOrder = triggers
		.map((btn, domIndex) => {
			const rect = btn.getBoundingClientRect();
			return { domIndex, x: rect.left, y: rect.top };
		})
		.sort((a, b) => {
			// Sort by column (x) first, then by row (y) within the same column
			const colThreshold = 50;
			const colA = Math.round(a.x / colThreshold);
			const colB = Math.round(b.x / colThreshold);
			if (colA !== colB) return colA - colB;
			return a.y - b.y;
		});

	// Reorder swiper slides to match visual order
	const slides = Array.from(swiperWrapper.children) as HTMLElement[];
	const reorderedSlides = visualOrder.map(v => slides[v.domIndex]);
	reorderedSlides.forEach(slide => swiperWrapper.appendChild(slide));

	// Build mapping: domIndex -> visual slide position
	const domToVisual = new Map<number, number>();
	visualOrder.forEach((v, visualIndex) => {
		domToVisual.set(v.domIndex, visualIndex);
	});

	const swiper = new Swiper('#lightbox-swiper', {
		modules: [Navigation, Keyboard],
		navigation: {
			nextEl: '.swiper-button-next',
			prevEl: '.swiper-button-prev',
		},
		keyboard: {
			enabled: false,
		},
		loop: true,
		speed: 300,
	});

	function open(domIndex: number) {
		isOpen = true;
		const visualIndex = domToVisual.get(domIndex) ?? domIndex;
		swiper.slideToLoop(visualIndex, 0);
		document.body.style.overflow = 'hidden';
		lightbox.style.pointerEvents = 'auto';
		lightbox.style.opacity = '1';
		lightbox.style.background = 'rgba(0,0,0,0.95)';
		closeBtn.style.opacity = '1';
		swiper.keyboard.enable();
	}

	function close() {
		isOpen = false;
		closeBtn.style.opacity = '0';
		lightbox.style.background = 'rgba(0,0,0,0)';
		lightbox.style.opacity = '0';
		swiper.keyboard.disable();
		setTimeout(() => {
			lightbox.style.pointerEvents = 'none';
			document.body.style.overflow = '';
		}, 300);
	}

	triggers.forEach(btn => {
		btn.addEventListener('click', () => {
			open(parseInt(btn.dataset.index!));
		});
	});

	closeBtn.addEventListener('click', (e) => {
		e.stopPropagation();
		close();
	});

	lightbox.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		if (target === lightbox || target.classList.contains('swiper-slide')) {
			close();
		}
	});

	document.addEventListener('keydown', (e) => {
		if (!isOpen) return;
		if (e.key === 'Escape') close();
	});
</script>
