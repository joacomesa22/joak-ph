---
interface Props {
	dark?: boolean;
}

const { dark = false } = Astro.props;
const currentPath = Astro.url.pathname;
const textColor = dark ? 'text-white/60' : 'text-neutral-500';
const activeColor = dark ? 'text-white' : 'text-neutral-900';
const hoverColor = dark ? 'hover:text-white' : 'hover:text-neutral-900';
---

<header class="px-6 md:px-12 py-6 flex items-center justify-between relative z-10">
	<a href="/" class:list={["text-lg font-medium tracking-tight hover:opacity-70 transition-opacity", dark ? "text-white" : "text-neutral-900"]}>
		joak.ph
	</a>
	<nav class:list={["flex gap-6 text-sm", textColor]}>
		<a href="/work" class:list={[hoverColor, "transition-colors", { [activeColor]: currentPath.startsWith("/work") || currentPath.startsWith("/gallery") }]}>
			Work
		</a>
		<a href="/about" class:list={[hoverColor, "transition-colors", { [activeColor]: currentPath === "/about" }]}>
			About
		</a>
		<a href="/contact" class:list={[hoverColor, "transition-colors", { [activeColor]: currentPath === "/contact" }]}>
			Contact
		</a>
	</nav>
</header>
