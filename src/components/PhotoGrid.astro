---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
	images: ImageMetadata[];
}

const { images } = Astro.props;
---

<div class="columns-1 sm:columns-2 lg:columns-3 gap-1 space-y-1 max-w-300 mx-auto">
	{images.map((img, i) => (
		<button
			class="block w-full break-inside-avoid cursor-pointer overflow-hidden"
			data-lightbox-trigger
			data-index={i}
		>
			<Image
				src={img}
				alt=""
				widths={[400, 800, 1200]}
				sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
				class="w-full h-auto transition-transform duration-500 hover:scale-[1.02]"
				loading={i < 6 ? "eager" : "lazy"}
			/>
		</button>
	))}
</div>
