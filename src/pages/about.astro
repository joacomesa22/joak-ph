---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import me from '../assets/me.jpg';
---

<Layout title="About — joak.ph">
	<section class="px-6 md:px-12 py-12  max-w-4xl">
		<h1 class="text-2xl md:text-3xl font-medium tracking-tight mb-8">About</h1>
		<div class="flex flex-col md:flex-row gap-10 items-start">
			<Image
				src={me}
				alt="Portrait"
				widths={[400, 800]}
				class="w-full md:w-72 shrink-0 object-cover"
			/>
			<div class="space-y-4 text-neutral-600 text-sm leading-relaxed">
				<p>
					Hello, I'm a photographer based in — . I focus on capturing
					authentic moments across travel, street, and portrait photography.
				</p>
				<p>
					This portfolio is a curated selection of my work. Feel free to reach out
					if you'd like to collaborate or have any questions.
				</p>
			</div>
		</div>
	</section>
</Layout>
