---
import Layout from '../layouts/Layout.astro';
import GalleryCard from '../components/GalleryCard.astro';
import { galleries } from '../data/galleries';

const sportsGalleries = galleries.filter(g => g.section === 'sports');
---

<Layout title="Sports — joak.ph">
	<section class="px-6 md:px-12 py-12">
		<h1 class="text-2xl md:text-3xl font-medium tracking-tight mb-12">Sports</h1>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-300 mx-auto">
			{sportsGalleries.map(gallery => (
				<GalleryCard
					title={gallery.title}
					slug={gallery.slug}
					cover={gallery.cover}
				/>
			))}
		</div>
	</section>
</Layout>
