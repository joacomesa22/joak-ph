---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — joak.ph">
	<section class="px-6 md:px-12 py-12  max-w-2xl">
		<h1 class="text-2xl md:text-3xl font-medium tracking-tight mb-8">Contact</h1>
		<div class="space-y-4 text-neutral-600 text-sm leading-relaxed">
			<p>
				For inquiries, collaborations, or prints, feel free to get in touch.
			</p>
			<ul class="space-y-2">
				<li>
					<span class="text-neutral-400">Email</span>
					<br />
					<a href="mailto:hello@joak.ph" class="hover:text-neutral-900 transition-colors">hello@joak.ph</a>
				</li>
				<li>
					<span class="text-neutral-400">Instagram</span>
					<br />
					<a href="https://instagram.com/" target="_blank" rel="noopener" class="hover:text-neutral-900 transition-colors">@joak.ph</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>
